# Non-sensitive production deployment settings.
# Secrets stay in GitHub Actions secrets.

ALLOWED_ACTOR="mattrbdr"
DEPLOY_BRANCH="main"
NODE_VERSION="24"

INSTALL_COMMAND="npm ci"
CHECK_COMMANDS="npm test"
BUILD_COMMAND="npm run build"
BUILD_OUTPUT="dist"

# Remote paths are relative to the O2Switch/cPanel home directory.
REMOTE_PATH="slacktomattermost.c.mrbdrs.fr"
BACKUP_PATH="backups/slacktomattermost"
KEEP_BACKUPS="5"
